import numpy as np


def wavefilter(wname, kind='d'):
    """
    Return wavelet decomposition filters (lp, hp) for wavelet name.
    kind: 'd' for decomposition.
    """
    try:
        import pywt
    except Exception as exc:
        raise ImportError("PyWavelets (pywt) is required for wavefilter.") from exc

    name = str(wname).lower()
    if name == 'jpeg9.7':
        name = 'bior4.4'
    w = pywt.Wavelet(name)
    kind = kind.lower()
    if kind == 'd':
        lp = np.array(w.dec_lo, dtype=float)
        hp = np.array(w.dec_hi, dtype=float)
    elif kind == 'r':
        lp = np.array(w.rec_lo, dtype=float)
        hp = np.array(w.rec_hi, dtype=float)
    else:
        raise ValueError("Only decomposition ('d') or reconstruction ('r') filters are supported.")
    return lp, hp
